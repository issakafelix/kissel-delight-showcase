# ── Client-side (Vite exposes VITE_* to the browser — these are public values) ──
# Firebase web app config (Project settings → General → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Paystack PUBLIC key (pk_test_… for testing, pk_live_… for real payments)
VITE_PAYSTACK_PUBLIC_KEY=

# ── Server-side only (set these in the Vercel dashboard, NEVER commit real values) ──
# Paystack SECRET key (sk_test_… / sk_live_…) — used by /api/orders to verify payments
PAYSTACK_SECRET_KEY=

# Firebase service account JSON, on ONE line (Project settings → Service accounts →
# Generate new private key, then paste the whole JSON here)
FIREBASE_SERVICE_ACCOUNT=
